# Gremlin server endpoint
GREMLIN_URL=ws://localhost:8182/gremlin

# Traversal source (commonly "g")
GREMLIN_TRAVERSAL_SOURCE=g

# Gremlin username
GREMLIN_USERNAME=your_username

# Gremlin password
GREMLIN_PASSWORD=your_password

# MCP transport: "stdio" or "streamable-http"
MCP_TRANSPORT=stdio

# ownCloud file storage (used to store generated diagrams and return a download link)
OWNCLOUD_URL=https://your-owncloud-instance.com/
OWNCLOUD_USERNAME=your_owncloud_username
OWNCLOUD_PASSWORD=your_owncloud_password
# Bearer token used for authentication against ownCloud Infinite Scale (oCIS):
# an app token (Settings -> Security / auth-app) or an OIDC access token.
# oCIS rejects HTTP Basic auth on WebDAV, so this is required there.
OWNCLOUD_TOKEN=
# Remote folder (collection) diagrams are uploaded into
OWNCLOUD_REMOTE_DIR=theo-diagrams
# Verify the TLS certificate. The default endpoint is an IP with a self-signed
# cert, so this is off by default; set to true if your instance has a valid cert.
OWNCLOUD_VERIFY_SSL=false
